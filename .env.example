# Copie este arquivo para .env e ajuste os valores conforme necessário

# Docling Server (Docker)
DOCLING_BASE_URL=http://localhost:5001

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=translategemma:4b
OLLAMA_TIMEOUT=600
TARGET_LANGUAGE=Portuguese (Brazil)

# Pastas de trabalho
INPUT_DIR=./input
OUTPUT_DIR=./output

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
