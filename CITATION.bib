@software{amaral2026docflow,
  author       = {Amaral, Maxwell Anderson Ielpo},
  title        = {{DocFlow}: Pipeline local de conversão, tradução e
                  exportação de documentos {PDF} via Docling e Ollama},
  year         = {2026},
  month        = mar,
  version      = {0.1.0},
  url          = {https://github.com/maxwellamaral/docflow},
  urldate      = {2026-03-09},
  note         = {Software de código aberto sob Licença Livre com
                  Citação Obrigatória. Desenvolvido com auxílio de
                  Inteligência Artificial Generativa (GitHub Copilot /
                  Claude Sonnet).},
  abstract     = {DocFlow é uma aplicação web local que orquestra um
                  pipeline de processamento de documentos PDF: conversão
                  para HTML estruturado via Docling Server (Docker + GPU),
                  tradução automática para Português (Brasil) via Ollama
                  com o modelo translategemma:4b, e exportação para os
                  formatos Word (.docx) e PDF. O backend é implementado
                  em Python 3.10+ com FastAPI e o frontend em Vue.js 3
                  com Vite.},
  keywords     = {pdf, conversão de documentos, tradução automática,
                  docling, ollama, fastapi, vue.js, pipeline,
                  inteligência artificial},
  license      = {Licença Livre com Citação Obrigatória}
